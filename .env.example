# ─────────────────────────────────────────────────────────────────────────────
# Indexcards_OCR — environment configuration
# Copy to `.env` (never commit `.env`). All values below are read by the backend.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenRouter (cloud VLM) ──────────────────────────────────────────────────
# Required only if you use the OpenRouter provider.
OPENROUTER_API_KEY=your_api_key_here

# ── Ollama (self-hosted / on-premise VLM) ───────────────────────────────────
# Point the app at YOUR OWN Ollama instance. No code change, no frontend rebuild:
# the frontend reads these (minus the secret parts) at runtime via GET /api/v1/config.
#
# Base URL of your Ollama server (OpenAI-compatible API). HTTP or HTTPS both work.
#   examples:  http://localhost:11434   https://ollama.your-institution.org
# OLLAMA_BASE_URL=http://localhost:11434
#
# Default model pre-selected in the UI when Ollama is chosen.
# OLLAMA_MODEL_NAME=qwen3-vl:235b
#
# Bearer token, if a reverse proxy in front of Ollama requires one (Ollama itself
# ignores it). Stays backend-only — never sent to the browser.
# OLLAMA_API_KEY=your-ollama-token
#
# Offer the Ollama provider in the UI at all (true/false).
# OLLAMA_ENABLED=true
#
# Cosmetic UI strings (safe to show in the browser — NOT the real URL).
# OLLAMA_LABEL=Ollama (self-hosted)
# OLLAMA_ENDPOINT_HINT=Lokal · on-premise
#
# Model filtering (priority: explicit allow-list → vision filter → all models)
#
# Explicit allow-list: only these exact model ids are offered in the UI.
# Comma-separated. Leave empty to use the vision filter below instead.
# OLLAMA_MODEL_ALLOWLIST=qwen3-vl:235b,qwen2.5vl:72b
#
# Vision filter (default ON): when no explicit allow-list is set, only show
# models whose id looks vision-capable — OCR needs a VLM. This hides the
# embedding/coder/text-only models a typical Ollama server has installed,
# without assuming specific model names. Set false to offer every model.
# OLLAMA_VISION_FILTER=true
#
# Substrings (case-insensitive) that mark a model id as vision-capable.
# Extend this if your local VLM uses a naming scheme not covered by default.
# OLLAMA_VISION_KEYWORDS=vl,vision,llava,-ocr,ocr:,minicpm-v,pixtral,granite3.2-vision,gemma3
#
# Per-request timeout (seconds) for one VLM call. Large models (e.g. qwen3-vl:235b)
# can take minutes per card — raise this if the logs show "Timeout. Retrying…".
# Applies to both OpenRouter and Ollama. Default 120.
# VLM_REQUEST_TIMEOUT_SECONDS=300

# ── Security / hardening (production) ───────────────────────────────────────
# Local single-curator dev needs NONE of these. Set them when deploying behind
# an authenticating reverse proxy. See docs/DEPLOYMENT.md.
#
# Interface the backend binds to. Keep localhost; expose via the proxy only.
# HOST=127.0.0.1
# Optional bearer token guarding the JSON API + WebSocket. Empty = disabled.
# AUTH_TOKEN=change-me-long-random
# Origins accepted for the WebSocket handshake (comma-separated).
# ALLOWED_WS_ORIGINS=https://indexcards.your-institution.org
# Expose /docs + openapi.json (keep false in production).
# ENABLE_DOCS=false
# Restrictive CORS allow-list (leave empty for same-origin behind a proxy).
# CORS_ALLOW_ORIGINS=
# Rate-limit storage — use redis:// when running more than one worker.
# RATE_LIMIT_STORAGE_URI=memory://

# ── Data retention (GDPR storage limitation — audit I-3) ────────────────────
# Encryption at rest is a DEPLOYMENT responsibility (LUKS/BitLocker/FileVault/
# encrypted volume), NOT done by the app. See docs/DEPLOYMENT.md.
#
# Auto-purge completed batches this many days after completion. 0 = OFF (default).
# Only 'completed' batches that are not active/exporting are ever purged.
# RETENTION_DAYS=0
# After a successful METS/MODS ingest export, purge the batch's working data.
# AUTO_PURGE_AFTER_EXPORT=false
# TTL (days) for the per-batch authority reconciliation cache. 0 = no expiry.
# AUTHORITY_CACHE_TTL_DAYS=0

# ── Security audit log (GDPR accountability — audit I-2) ────────────────────
# Append-only JSONL log of security events (start/cancel/delete/export/purge/
# config changes/auth failures). Never contains OCR text, metadata, or secrets.
# AUDIT_ENABLED=true
# AUDIT_LOG_FILE=data/audit.log.jsonl
# Trusted proxy header carrying the SSO user (name is configurable).
# AUDIT_USER_HEADER=X-Forwarded-User
# Proxy IPs/CIDRs whose user header is trusted. Empty = never trust it (actor
# recorded as "unknown"). MUST be set for real per-user accountability.
# TRUSTED_PROXY_IPS=10.0.0.1,192.168.0.0/16

# ── Authority reconciliation (optional) ─────────────────────────────────────
# GEONAMES_USERNAME=your_geonames_username

# ── LLM corrector (optional) ────────────────────────────────────────────────
# CORRECTOR_MODEL_NAME=anthropic/claude-haiku-4
