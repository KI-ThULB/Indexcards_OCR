# ─────────────────────────────────────────────────────────────────────────────
# Indexcards_OCR — environment configuration
# Copy to `.env` (never commit `.env`). All values below are read by the backend.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenRouter (cloud VLM) ──────────────────────────────────────────────────
# Required only if you use the OpenRouter provider.
OPENROUTER_API_KEY=your_api_key_here

# ── Ollama (self-hosted / on-premise VLM) ───────────────────────────────────
# Point the app at YOUR OWN Ollama instance. No code change, no frontend rebuild:
# the frontend reads these (minus the secret parts) at runtime via GET /api/v1/config.
#
# Base URL of your Ollama server (OpenAI-compatible API). HTTP or HTTPS both work.
#   examples:  http://localhost:11434   https://ollama.your-institution.org
# OLLAMA_BASE_URL=http://localhost:11434
#
# Default model pre-selected in the UI when Ollama is chosen.
# OLLAMA_MODEL_NAME=qwen3-vl:235b
#
# Bearer token, if a reverse proxy in front of Ollama requires one (Ollama itself
# ignores it). Stays backend-only — never sent to the browser.
# OLLAMA_API_KEY=your-ollama-token
#
# Offer the Ollama provider in the UI at all (true/false).
# OLLAMA_ENABLED=true
#
# Cosmetic UI strings (safe to show in the browser — NOT the real URL).
# OLLAMA_LABEL=Ollama (self-hosted)
# OLLAMA_ENDPOINT_HINT=Lokal · on-premise
#
# Model filtering (priority: explicit allow-list → vision filter → all models)
#
# Explicit allow-list: only these exact model ids are offered in the UI.
# Comma-separated. Leave empty to use the vision filter below instead.
# OLLAMA_MODEL_ALLOWLIST=qwen3-vl:235b,qwen2.5vl:72b
#
# Vision filter (default ON): when no explicit allow-list is set, only show
# models whose id looks vision-capable — OCR needs a VLM. This hides the
# embedding/coder/text-only models a typical Ollama server has installed,
# without assuming specific model names. Set false to offer every model.
# OLLAMA_VISION_FILTER=true
#
# Substrings (case-insensitive) that mark a model id as vision-capable.
# Extend this if your local VLM uses a naming scheme not covered by default.
# OLLAMA_VISION_KEYWORDS=vl,vision,llava,-ocr,ocr:,minicpm-v,pixtral,granite3.2-vision,gemma3

# ── Authority reconciliation (optional) ─────────────────────────────────────
# GEONAMES_USERNAME=your_geonames_username

# ── LLM corrector (optional) ────────────────────────────────────────────────
# CORRECTOR_MODEL_NAME=anthropic/claude-haiku-4
